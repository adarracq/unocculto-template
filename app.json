{
  "expo": {
    "name": "unocculto-template",
    "slug": "unocculto-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_white.png",
    "scheme": "unoccultotemplate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo_white.png",
      "bundleIdentifier": "com.antoinecd.unoccultotemplate"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_white.png",
        "backgroundColor": "#121212"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.antoinecd.unoccultotemplate"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_white.png"
    },
    "plugins": [
      "expo-router",
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "v11": true
          },
          "ios": {
            "v11": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2fd68470-fb45-41db-9bdc-b694933be91f"
      }
    }
  }
}
